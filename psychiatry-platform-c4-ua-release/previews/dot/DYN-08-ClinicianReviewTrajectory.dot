}
step_01 [label=< <B>1.</B> Лікар-психіатр → Кабінет медичного працівника<BR/><FONT POINT-SIZE="10">Відкриває випадок і часову шкалу</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_02 [label=< <B>2.</B> Кабінет медичного працівника → API-шлюз і BFF<BR/><FONT POINT-SIZE="10">Запитує результати, прапорці та джерела</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_01 -> step_02;
step_03 [label=< <B>3.</B> API-шлюз і BFF → Сервіс підтримки клінічних<BR/>рішень<BR/><FONT POINT-SIZE="10">Отримує проєкт узагальнення та пояснення</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_02 -> step_03;
step_04 [label=< <B>4.</B> Сервіс підтримки клінічних<BR/>рішень → Репозиторій клінічних<BR/>протоколів і знань<BR/><FONT POINT-SIZE="10">Перевіряє релевантні протоколи</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_03 -> step_04;
step_05 [label=< <B>5.</B> Сервіс підтримки клінічних<BR/>рішень → Клінічне сховище<BR/><FONT POINT-SIZE="10">Зберігає коригування та підтверджене рішення</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_04 -> step_05;
step_06 [label=< <B>6.</B> Сервіс підтримки клінічних<BR/>рішень → Сервіс завдань, нагадувань і<BR/>ескалацій<BR/><FONT POINT-SIZE="10">Створює погоджені контрольні точки</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_05 -> step_06;
step_07 [label=< <B>7.</B> Сервіс підтримки клінічних<BR/>рішень → Сервіс аудиту та<BR/>спостережуваності<BR/><FONT POINT-SIZE="10">Фіксує фахівця, обґрунтування й версію джерел</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_06 -> step_07;
}
