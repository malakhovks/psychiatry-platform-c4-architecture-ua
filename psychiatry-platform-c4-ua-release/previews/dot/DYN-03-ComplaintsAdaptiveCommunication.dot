}
step_01 [label=< <B>1.</B> Пацієнт → Застосунок пацієнта<BR/><FONT POINT-SIZE="10">Описує скарги, потреби та мету звернення</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_02 [label=< <B>2.</B> Застосунок пацієнта → API-шлюз і BFF<BR/><FONT POINT-SIZE="10">Передає текст, транскрипт або медіа за згодою</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_01 -> step_02;
step_03 [label=< <B>3.</B> API-шлюз і BFF → Оркестратор взаємодії<BR/><FONT POINT-SIZE="10">Створює подію введення</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_02 -> step_03;
step_04 [label=< <B>4.</B> Оркестратор взаємодії → Оркестратор ШІ та контроль<BR/>безпеки<BR/><FONT POINT-SIZE="10">Структурує вільний текст і визначає невизначені поля</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_03 -> step_04;
step_05 [label=< <B>5.</B> Оркестратор взаємодії → Клінічне сховище<BR/><FONT POINT-SIZE="10">Зберігає підтверджені структуровані дані та джерело</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_04 -> step_05;
step_06 [label=< <B>6.</B> Оркестратор взаємодії → Детермінований рушій<BR/>сценаріїв<BR/><FONT POINT-SIZE="10">Отримує наступне уточнення або формальний крок</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_05 -> step_06;
step_07 [label=< <B>7.</B> Оркестратор взаємодії → Сервіс аудиту та<BR/>спостережуваності<BR/><FONT POINT-SIZE="10">Фіксує канал, політику стилю та походження репліки</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_06 -> step_07;
}
