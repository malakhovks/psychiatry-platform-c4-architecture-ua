label=<<B>DYN.04 — Опитувальник, розгалуження та обчислення балів</B><BR/><FONT POINT-SIZE="11">Внутрішній детермінований процес виконання опитувальника, розгалуження, оцінювання та<BR/>формування результату.</FONT>>;
{ rank=same;
p_n_a2ddeaf00067 [label=<<B>Завантажувач<BR/>визначення</B>>, fillcolor="#F4F7FA", fontcolor="#18324A", color="#486581", shape=box];
