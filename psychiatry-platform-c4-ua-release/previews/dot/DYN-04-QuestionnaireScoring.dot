}
step_01 [label=< <B>1.</B> Завантажувач визначення → Реєстр алгоритмів<BR/><FONT POINT-SIZE="10">Отримує підписану версію визначення</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_02 [label=< <B>2.</B> Завантажувач визначення → Валідатор визначення<BR/><FONT POINT-SIZE="10">Передає визначення на повторну перевірку</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_01 -> step_02;
step_03 [label=< <B>3.</B> Валідатор визначення → Інтерпретатор станів<BR/><FONT POINT-SIZE="10">Активує валідний граф станів</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_02 -> step_03;
step_04 [label=< <B>4.</B> Валідатор відповіді → Інтерпретатор станів<BR/><FONT POINT-SIZE="10">Передає типізовану відповідь</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_03 -> step_04;
step_05 [label=< <B>5.</B> Інтерпретатор станів → Селектор наступного кроку<BR/><FONT POINT-SIZE="10">Запитує наступний допустимий крок</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_04 -> step_05;
step_06 [label=< <B>6.</B> Селектор наступного кроку → Оцінювач переходів<BR/><FONT POINT-SIZE="10">Перевіряє умови переходу</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_05 -> step_06;
step_07 [label=< <B>7.</B> Оцінювач переходів → Калькулятор балів<BR/><FONT POINT-SIZE="10">Передає релевантні відповіді</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_06 -> step_07;
step_08 [label=< <B>8.</B> Калькулятор балів → Оцінювач червоних прапорців<BR/><FONT POINT-SIZE="10">Обчислює бали та передає критичні ознаки</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_07 -> step_08;
step_09 [label=< <B>9.</B> Оцінювач червоних прапорців → Формувач результату<BR/><FONT POINT-SIZE="10">Додає прапорці й пріоритет</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_08 -> step_09;
step_10 [label=< <B>10.</B> Формувач результату → Фіксація походження<BR/><FONT POINT-SIZE="10">Формує структурований результат</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_09 -> step_10;
step_11 [label=< <B>11.</B> Формувач результату → Сервіс підтримки клінічних<BR/>рішень<BR/><FONT POINT-SIZE="10">Передає результат до підтримки клінічних рішень</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_10 -> step_11;
step_12 [label=< <B>12.</B> Фіксація походження → Клінічне сховище<BR/><FONT POINT-SIZE="10">Зберігає результат і відтворюване походження</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_11 -> step_12;
step_13 [label=< <B>13.</B> Фіксація походження → Сервіс аудиту та<BR/>спостережуваності<BR/><FONT POINT-SIZE="10">Реєструє доказ виконання</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_12 -> step_13;
}
