digraph G {
graph [rankdir=TB, bgcolor="white", pad="0.35", nodesep="0.25", ranksep="0.30", fontname="DejaVu Sans", labelloc=t, labeljust=l];
node [fontname="DejaVu Sans", fontsize=12, shape=box, style="rounded,filled", fillcolor="#F4F7FA", color="#486581", margin="0.16,0.10"];
edge [color="#7B8794", penwidth=1.2, arrowsize=0.7];
label=<<B>DYN.13 — Призупинення та відновлення сесії</B><BR/><FONT POINT-SIZE="11">Безпечне призупинення та відновлення незавершеної сесії без втрати версії алгоритму й<BR/>контексту.</FONT>>;
{ rank=same;
p_n_b1b0b8de8a62 [label=<<B>Пацієнт</B>>, fillcolor="#084C61", fontcolor="#FFFFFF", color="#486581", shape=box];
p_n_8a923be70a11 [label=<<B>Застосунок пацієнта</B>>, fillcolor="#0B7285", fontcolor="#FFFFFF", color="#486581", shape=box];
p_n_384146de0c5d [label=<<B>API-шлюз і BFF</B>>, fillcolor="#F4F7FA", fontcolor="#18324A", color="#486581", shape=box];
p_n_f9075d486a51 [label=<<B>Оркестратор взаємодії</B>>, fillcolor="#F4F7FA", fontcolor="#18324A", color="#486581", shape=box];
p_n_331a3889c3d6 [label=<<B>Операційна база даних</B>>, fillcolor="#EDF2F7", fontcolor="#1A202C", color="#486581", shape=box];
p_n_eb4c5110ae64 [label=<<B>Сервіс завдань,<BR/>нагадувань і ескалацій</B>>, fillcolor="#B7791F", fontcolor="#FFFFFF", color="#486581", shape=box];
p_n_b10c10dbc143 [label=<<B>Інтеграційний шлюз</B>>, fillcolor="#3B5BDB", fontcolor="#FFFFFF", color="#486581", shape=box];
p_n_dff60b2c2060 [label=<<B>Провайдер повідомлень</B>>, fillcolor="#E9EEF4", fontcolor="#263238", color="#486581", shape=box];
p_n_85612016a131 [label=<<B>Кеш і короткоживучий<BR/>стан</B>>, fillcolor="#EDF2F7", fontcolor="#1A202C", color="#486581", shape=box];
p_n_78e6a86e3609 [label=<<B>Детермінований рушій<BR/>сценаріїв</B>>, fillcolor="#2B6CB0", fontcolor="#FFFFFF", color="#486581", shape=box];
}
step_01 [label=< <B>1.</B> Пацієнт → Застосунок пацієнта<BR/><FONT POINT-SIZE="10">Просить зберегти прогрес або втрачає з&#x27;єднання</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_02 [label=< <B>2.</B> Застосунок пацієнта → API-шлюз і BFF<BR/><FONT POINT-SIZE="10">Передає останній підтверджений стан</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_01 -> step_02;
step_03 [label=< <B>3.</B> API-шлюз і BFF → Оркестратор взаємодії<BR/><FONT POINT-SIZE="10">Позначає сесію як призупинену</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_02 -> step_03;
step_04 [label=< <B>4.</B> Оркестратор взаємодії → Операційна база даних<BR/><FONT POINT-SIZE="10">Фіксує поточний крок і закріплену версію алгоритму</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_03 -> step_04;
step_05 [label=< <B>5.</B> Оркестратор взаємодії → Сервіс завдань, нагадувань і<BR/>ескалацій<BR/><FONT POINT-SIZE="10">Створює ненав&#x27;язливе нагадування</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_04 -> step_05;
step_06 [label=< <B>6.</B> Сервіс завдань, нагадувань і<BR/>ескалацій → Інтеграційний шлюз<BR/><FONT POINT-SIZE="10">Передає нагадування</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_05 -> step_06;
step_07 [label=< <B>7.</B> Інтеграційний шлюз → Провайдер повідомлень<BR/><FONT POINT-SIZE="10">Надсилає мінімізоване повідомлення</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_06 -> step_07;
step_08 [label=< <B>8.</B> Пацієнт → Застосунок пацієнта<BR/><FONT POINT-SIZE="10">Повертається до сесії</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_07 -> step_08;
step_09 [label=< <B>9.</B> Застосунок пацієнта → API-шлюз і BFF<BR/><FONT POINT-SIZE="10">Запитує відновлення</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_08 -> step_09;
step_10 [label=< <B>10.</B> API-шлюз і BFF → Оркестратор взаємодії<BR/><FONT POINT-SIZE="10">Відновлює стан після повторної перевірки доступу</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_09 -> step_10;
step_11 [label=< <B>11.</B> Оркестратор взаємодії → Кеш і короткоживучий стан<BR/><FONT POINT-SIZE="10">Відновлює короткоживучий контекст і блокування</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_10 -> step_11;
step_12 [label=< <B>12.</B> Оркестратор взаємодії → Детермінований рушій<BR/>сценаріїв<BR/><FONT POINT-SIZE="10">Продовжує з чинного кроку тієї самої версії</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_11 -> step_12;
}
