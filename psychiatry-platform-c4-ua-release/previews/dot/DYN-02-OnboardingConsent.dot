step_05 [label=< <B>5.</B> Сервіс ідентичності, доступу<BR/>та згод → Клінічне сховище<BR/><FONT POINT-SIZE="10">Фіксує версію інформування, обсяг і строк згоди</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
