step_04 [label=< <B>4.</B> Сервіс ідентичності, доступу<BR/>та згод → Постачальник електронної<BR/>ідентичності<BR/><FONT POINT-SIZE="10">Перевіряє електронну ідентичність і MFA</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
