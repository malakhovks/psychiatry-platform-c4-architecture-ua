step_06 [label=< <B>6.</B> Сервіс ідентичності, доступу<BR/>та згод → Сервіс аудиту та<BR/>спостережуваності<BR/><FONT POINT-SIZE="10">Реєструє рішення доступу та знімок згод</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_05 -> step_06;
step_07 [label=< <B>7.</B> API-шлюз і BFF → Сервіс аудиту та<BR/>спостережуваності<BR/><FONT POINT-SIZE="10">Реєструє результат початкового запиту</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
