step_01 [label=< <B>1.</B> Пацієнт → Застосунок пацієнта<BR/><FONT POINT-SIZE="10">Відкриває застосунок і обирає спосіб входу</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_02 [label=< <B>2.</B> Застосунок пацієнта → API-шлюз і BFF<BR/><FONT POINT-SIZE="10">Запитує початок сесії</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
