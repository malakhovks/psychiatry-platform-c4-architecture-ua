edge [color="#7B8794", penwidth=1.2, arrowsize=0.7];
label=<<B>DYN.09 — Підготовка до візиту та маршрутизація</B><BR/><FONT POINT-SIZE="11">Підготовка пацієнта до візиту та маршрутизація до відповідного фахівця.</FONT>>;
{ rank=same;
p_n_b1b0b8de8a62 [label=<<B>Пацієнт</B>>, fillcolor="#084C61", fontcolor="#FFFFFF", color="#486581", shape=box];
p_n_8a923be70a11 [label=<<B>Застосунок пацієнта</B>>, fillcolor="#0B7285", fontcolor="#FFFFFF", color="#486581", shape=box];
p_n_384146de0c5d [label=<<B>API-шлюз і BFF</B>>, fillcolor="#F4F7FA", fontcolor="#18324A", color="#486581", shape=box];
p_n_f9075d486a51 [label=<<B>Оркестратор взаємодії</B>>, fillcolor="#F4F7FA", fontcolor="#18324A", color="#486581", shape=box];
p_n_c210e7db8afd [label=<<B>Сервіс підтримки<BR/>клінічних рішень</B>>, fillcolor="#2B6CB0", fontcolor="#FFFFFF", color="#486581", shape=box];
p_n_eb4c5110ae64 [label=<<B>Сервіс завдань,<BR/>нагадувань і ескалацій</B>>, fillcolor="#B7791F", fontcolor="#FFFFFF", color="#486581", shape=box];
p_n_b10c10dbc143 [label=<<B>Інтеграційний шлюз</B>>, fillcolor="#3B5BDB", fontcolor="#FFFFFF", color="#486581", shape=box];
p_n_d41792c094aa [label=<<B>Календар і запис на<BR/>прийом</B>>, fillcolor="#E9EEF4", fontcolor="#263238", color="#486581", shape=box];
p_n_8ef8376f7755 [label=<<B>Платформа телемедицини</B>>, fillcolor="#E9EEF4", fontcolor="#263238", color="#486581", shape=box];
}
step_01 [label=< <B>1.</B> Пацієнт → Застосунок пацієнта<BR/><FONT POINT-SIZE="10">Запитує підготовку до консультації</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_02 [label=< <B>2.</B> Застосунок пацієнта → API-шлюз і BFF<BR/><FONT POINT-SIZE="10">Передає запит із дозволеним контекстом</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_01 -> step_02;
step_03 [label=< <B>3.</B> API-шлюз і BFF → Оркестратор взаємодії<BR/><FONT POINT-SIZE="10">Формує зрозумілий підсумок і перелік питань</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_02 -> step_03;
step_04 [label=< <B>4.</B> API-шлюз і BFF → Сервіс підтримки клінічних<BR/>рішень<BR/><FONT POINT-SIZE="10">Визначає допустимі варіанти маршруту</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_03 -> step_04;
step_05 [label=< <B>5.</B> Сервіс підтримки клінічних<BR/>рішень → Сервіс завдань, нагадувань і<BR/>ескалацій<BR/><FONT POINT-SIZE="10">Передає роль фахівця, пріоритет і часові межі</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_04 -> step_05;
step_06 [label=< <B>6.</B> Сервіс завдань, нагадувань і<BR/>ескалацій → Інтеграційний шлюз<BR/><FONT POINT-SIZE="10">Запитує доступний слот або телемедичний сеанс</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_05 -> step_06;
step_07 [label=< <B>7.</B> Інтеграційний шлюз → Календар і запис на прийом<BR/><FONT POINT-SIZE="10">Створює або резервує подію</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_06 -> step_07;
step_08 [label=< <B>8.</B> Інтеграційний шлюз → Платформа телемедицини<BR/><FONT POINT-SIZE="10">За потреби створює захищений дистанційний сеанс</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_07 -> step_08;
}
