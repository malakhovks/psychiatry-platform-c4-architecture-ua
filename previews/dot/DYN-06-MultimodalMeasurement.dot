step_01 [label=< <B>1.</B> Медичні пристрої та сенсори → Шлюз пристроїв<BR/><FONT POINT-SIZE="10">Передає дозволений сигнал і технічні метадані</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_02 [label=< <B>2.</B> Шлюз пристроїв → Контроль якості<BR/><FONT POINT-SIZE="10">Передає потік для перевірки якості</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_01 -> step_02;
step_03 [label=< <B>3.</B> Контроль якості → Попереднє оброблення<BR/>сигналів<BR/><FONT POINT-SIZE="10">Допускає придатні дані до оброблення</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_02 -> step_03;
step_04 [label=< <B>4.</B> Попереднє оброблення<BR/>сигналів → Аналізатор ЕКГ / Мінесотське<BR/>кодування<BR/><FONT POINT-SIZE="10">Передає ЕКГ для кодування й виділення ознак</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_03 -> step_04;
step_05 [label=< <B>5.</B> Попереднє оброблення<BR/>сигналів → Аналізатор голосу<BR/><FONT POINT-SIZE="10">Передає аудіо для дозволеного аналізу</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_04 -> step_05;
step_06 [label=< <B>6.</B> Попереднє оброблення<BR/>сигналів → Аналізатор відео<BR/><FONT POINT-SIZE="10">Передає відео для дозволеного аналізу</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_05 -> step_06;
step_07 [label=< <B>7.</B> Попереднє оброблення<BR/>сигналів → Аналізатор медичних<BR/>зображень<BR/><FONT POINT-SIZE="10">Передає підтримуване медичне зображення</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_06 -> step_07;
step_08 [label=< <B>8.</B> Аналізатор ЕКГ / Мінесотське<BR/>кодування → Об&#x27;єднання ознак<BR/><FONT POINT-SIZE="10">Додає коди й ознаки ЕКГ</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_07 -> step_08;
step_09 [label=< <B>9.</B> Аналізатор голосу → Об&#x27;єднання ознак<BR/><FONT POINT-SIZE="10">Додає голосові ознаки</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_08 -> step_09;
step_10 [label=< <B>10.</B> Аналізатор відео → Об&#x27;єднання ознак<BR/><FONT POINT-SIZE="10">Додає відеоознаки</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_09 -> step_10;
step_11 [label=< <B>11.</B> Аналізатор медичних<BR/>зображень → Об&#x27;єднання ознак<BR/><FONT POINT-SIZE="10">Додає зображувальні ознаки</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_10 -> step_11;
step_12 [label=< <B>12.</B> Об&#x27;єднання ознак → Нормалізатор результату<BR/><FONT POINT-SIZE="10">Формує узгоджений результат із внеском модальностей</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_11 -> step_12;
step_13 [label=< <B>13.</B> Нормалізатор результату → Клінічне сховище<BR/><FONT POINT-SIZE="10">Зберігає показники, якість і версію аналізатора</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_12 -> step_13;
step_14 [label=< <B>14.</B> Нормалізатор результату → Сервіс аудиту та<BR/>спостережуваності<BR/><FONT POINT-SIZE="10">Фіксує ланцюг оброблення</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_13 -> step_14;
