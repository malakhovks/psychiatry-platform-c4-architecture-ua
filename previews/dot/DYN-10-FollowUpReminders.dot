}
step_01 [label=< <B>1.</B> Детермінований рушій<BR/>сценаріїв → Сервіс завдань, нагадувань і<BR/>ескалацій<BR/><FONT POINT-SIZE="10">Створює повторне опитування або вимірювання</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_02 [label=< <B>2.</B> Сервіс завдань, нагадувань і<BR/>ескалацій → Інтеграційний шлюз<BR/><FONT POINT-SIZE="10">Передає нагадування дозволеним каналом</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_01 -> step_02;
step_03 [label=< <B>3.</B> Інтеграційний шлюз → Провайдер повідомлень<BR/><FONT POINT-SIZE="10">Надсилає мінімізоване повідомлення</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_02 -> step_03;
step_04 [label=< <B>4.</B> Інтеграційний шлюз → Календар і запис на прийом<BR/><FONT POINT-SIZE="10">Оновлює календарну подію</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_03 -> step_04;
step_05 [label=< <B>5.</B> Пацієнт → Застосунок пацієнта<BR/><FONT POINT-SIZE="10">Повертається до запланованого завдання</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_04 -> step_05;
step_06 [label=< <B>6.</B> Застосунок пацієнта → API-шлюз і BFF<BR/><FONT POINT-SIZE="10">Підтверджує виконання або повідомляє причину пропуску</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_05 -> step_06;
step_07 [label=< <B>7.</B> API-шлюз і BFF → Сервіс завдань, нагадувань і<BR/>ескалацій<BR/><FONT POINT-SIZE="10">Оновлює статус завдання</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_06 -> step_07;
step_08 [label=< <B>8.</B> Сервіс завдань, нагадувань і<BR/>ескалацій → Шина доменних подій<BR/><FONT POINT-SIZE="10">Публікує виконання або прострочення</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_07 -> step_08;
step_09 [label=< <B>9.</B> Шина доменних подій → Сервіс аудиту та<BR/>спостережуваності<BR/><FONT POINT-SIZE="10">Фіксує подію й резервний маршрут</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_08 -> step_09;
}
