}
step_01 [label=< <B>1.</B> Оркестратор взаємодії → Менеджер шаблонів і політик<BR/><FONT POINT-SIZE="10">Передає завдання, локаль і дозволений контекст</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_02 [label=< <B>2.</B> Менеджер шаблонів і політик → Пошук у базі знань<BR/><FONT POINT-SIZE="10">Запитує дозволені джерела</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_01 -> step_02;
step_03 [label=< <B>3.</B> Пошук у базі знань → База знань та індекс пошуку<BR/><FONT POINT-SIZE="10">Отримує фрагменти з версією і посиланням</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_02 -> step_03;
step_04 [label=< <B>4.</B> Менеджер шаблонів і політик → Клінічні та контентні<BR/>запобіжники<BR/><FONT POINT-SIZE="10">Застосовує клінічні та приватнісні обмеження</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_03 -> step_04;
step_05 [label=< <B>5.</B> Клінічні та контентні<BR/>запобіжники → Маршрутизатор моделей<BR/><FONT POINT-SIZE="10">Дозволяє мінімізований запит</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_04 -> step_05;
step_06 [label=< <B>6.</B> Пошук у базі знань → Маршрутизатор моделей<BR/><FONT POINT-SIZE="10">Передає дозволений контекст</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_05 -> step_06;
step_07 [label=< <B>7.</B> Маршрутизатор моделей → Реєстр і середовище моделей<BR/>ШІ<BR/><FONT POINT-SIZE="10">Викликає обрану локальну або зовнішню модель</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_06 -> step_07;
step_08 [label=< <B>8.</B> Маршрутизатор моделей → Валідатор структурованого<BR/>виходу<BR/><FONT POINT-SIZE="10">Передає відповідь на перевірку контракту</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_07 -> step_08;
step_09 [label=< <B>9.</B> Валідатор структурованого<BR/>виходу → Клінічні та контентні<BR/>запобіжники<BR/><FONT POINT-SIZE="10">Виконує післягенераційний контроль</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_08 -> step_09;
step_10 [label=< <B>10.</B> Клінічні та контентні<BR/>запобіжники → Компонувальник відповіді<BR/><FONT POINT-SIZE="10">Передає лише дозволений зміст</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_09 -> step_10;
step_11 [label=< <B>11.</B> Компонувальник відповіді → Контроль людиною<BR/><FONT POINT-SIZE="10">Маркує клінічно значущий проєкт</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_10 -> step_11;
step_12 [label=< <B>12.</B> Контроль людиною → Сервіс аудиту та<BR/>спостережуваності<BR/><FONT POINT-SIZE="10">Фіксує модель, шаблон, джерела й режим контролю</FONT> >, fillcolor="#FFFFFF", color="#486581", penwidth=1.5];
step_11 -> step_12;
}
